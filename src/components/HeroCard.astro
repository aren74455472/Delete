---
const { title, chinese, desc, color, link } = Astro.props;
---

<a href={link} class="hero-card-link">
    <div class="hero-card">
        <div class="content">
            <span class="en-title">{title}</span>
            <h2 class="zh-title">{chinese}</h2>
            <p class="desc">{desc}</p>
        </div>
    </div>
</a>

<style define:vars={{ themeColor: color }}>
    .hero-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
    }

    .hero-card {
        background: #fff;
        border-left: 5px solid var(--themeColor); /* 用左边条区分板块 */
        padding: 1.5rem;
        height: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .hero-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        background-color: var(--themeColor); /* 悬停时变色 */
        color: white;
    }

    .en-title {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.7;
    }

    .zh-title {
        margin: 0.5rem 0;
        font-size: 1.5rem;
    }

    .desc {
        font-size: 0.9rem;
        margin-bottom: 0;
        opacity: 0.8;
    }
</style>
