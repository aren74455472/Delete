---
import { TAG_CONFIG } from "../content.consts";

interface Props {
    name: string;
}

const { name } = Astro.props;

// 优先匹配字典里的样式，匹配不到就用 default
const config = TAG_CONFIG[name] || TAG_CONFIG.default;
---

<span class="custom-badge">
    {name}
</span>

<style
    define:vars={{
        tagColor: config.color,
        tagFont: config.font,
    }}
>
    .custom-badge {
        display: inline-block;
        padding: 2px 12px;
        margin-right: 6px;
        margin-bottom: 4px;

        /* 形状：胶囊 */
        border-radius: 50px;
        border: 1px solid rgba(0, 0, 0, 0.05);

        /* 视觉设计 */
        background-color: var(--tagColor);
        color: var(--tagColor);
        font-family: var(--tagFont);
        font-size: 0.75rem;
        font-weight: 500;

        /* 交互 */
        transition: transform 0.2s ease;
        cursor: default;
        vertical-align: middle;
    }
    .custom-badge:hover {
        transform: scale(1.05); /* 鼠标指上去微微放大 */
    }
</style>
