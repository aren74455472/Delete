---
const { title = "Alcedo" } = Astro.props;
const pathname = Astro.url.pathname;
---

<html lang="zh">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>

        <!-- Bootstrap -->
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        />

        <!-- Global Style -->
        <style>
            body {
                font-family:
                    system-ui,
                    -apple-system,
                    "Segoe UI",
                    Roboto,
                    "Helvetica Neue",
                    Arial;
                background-color: #fafafa;
            }

            .navbar {
                background-color: rgba(255, 255, 255, 0.8) !important;
                backdrop-filter: blur(6px);
            }

            .card {
                border-radius: 12px;
                border: 1px solid rgba(0, 0, 0, 0.08);
                transition: all 0.2s ease;
            }

            .card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            }

            a {
                text-decoration: none;
            }

            .text-muted {
                color: #777 !important;
            }

            .nav-active {
                position: relative;
                font-weight: 600;
            }

            .nav-active::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -4px;
                width: 100%;
                height: 2px;
                background: black;
            }
        </style>
    </head>

    <body>
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg border-bottom px-3">
            <div class="container justify-content-center">
                <a
                    class={`navbar-brand ${pathname === "/" ? "nav-active" : ""}`}
                    href="/"
                >
                    Alcedo
                </a>

                <div class="navbar-nav flex-row gap-3">
                    <a
                        class={`nav-link ${pathname === "/creation" ? "nav-active" : ""}`}
                        href="/creation"
                    >
                        Creation
                    </a>

                    <a
                        class={`nav-link ${pathname === "/daily" ? "nav-active" : ""}`}
                        href="/daily"
                    >
                        Daily
                    </a>

                    <a
                        class={`nav-link ${pathname === "/media" ? "nav-active" : ""}`}
                        href="/media"
                    >
                        Media
                    </a>

                    <a
                        class={`nav-link ${pathname === "/projects" ? "nav-active" : ""}`}
                        href="/projects"
                    >
                        Projects
                    </a>
                </div>
            </div>
        </nav>

        <!-- Page content -->
        <main class="container py-4">
            <slot />
        </main>
    </body>
</html>
